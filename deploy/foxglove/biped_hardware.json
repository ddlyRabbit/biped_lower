            { "value": "/joint_states.position[2]", "enabled": true, "timestampMethod": "receiveTime" },
            { "value": "/joint_states.position[3]", "enabled": true, "timestampMethod": "receiveTime" },
            { "value": "/joint_states.position[4]", "enabled": true, "timestampMethod": "receiveTime" },
            { "value": "/joint_states.position[5]", "enabled": true, "timestampMethod": "receiveTime" }
