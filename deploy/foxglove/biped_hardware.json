{
  "layout": {
    "direction": "row",
    "first": {
      "direction": "column",
      "first": {
        "direction": "row",
        "first": {
          "id": "3d-imu",
          "type": "panel",
          "title": "IMU Orientation",
          "config": {
            "panelType": "3D",
            "topics": {
              "/imu/data": { "visible": true }
            }
          }
        },
        "second": {
          "id": "plot-gravity",
          "type": "panel",
          "title": "Gravity (m/s²)",
          "config": {
            "panelType": "Plot",
            "paths": [
              { "value": "/imu/gravity.vector.x", "enabled": true, "timestampMethod": "receiveTime" },
              { "value": "/imu/gravity.vector.y", "enabled": true, "timestampMethod": "receiveTime" },
              { "value": "/imu/gravity.vector.z", "enabled": true, "timestampMethod": "receiveTime" }
            ],
            "minYValue": -12,
            "maxYValue": 12
          }
        },
        "splitPercentage": 40
      },
      "second": {
        "id": "plot-gyro",
        "type": "panel",
        "title": "Gyro (rad/s)",
        "config": {
          "panelType": "Plot",
          "paths": [
            { "value": "/imu/data.angular_velocity.x", "enabled": true, "timestampMethod": "receiveTime" },
            { "value": "/imu/data.angular_velocity.y", "enabled": true, "timestampMethod": "receiveTime" },
            { "value": "/imu/data.angular_velocity.z", "enabled": true, "timestampMethod": "receiveTime" }
          ],
          "minYValue": -5,
          "maxYValue": 5
        }
      },
      "splitPercentage": 65
